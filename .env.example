# Copy this file to `.env` and adjust. `.env` is gitignored — real keys never enter git.
#
# The LLM is reached through an OpenAI-compatible endpoint, so switching providers
# is just a matter of changing these three variables:
#
#   Local dev (Ollama):   LLM_BASE_URL=http://localhost:11434/v1   LLM_API_KEY=ollama (any string works)
#   Deployed  (Groq):     LLM_BASE_URL=https://api.groq.com/openai/v1   LLM_API_KEY=<your groq key>
#                         LLM_MODEL=llama-3.3-70b-versatile   JUDGE_MODEL=llama-3.1-8b-instant

LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b

# Model used for LLM-as-judge calls (citation verification, eval grading).
# Locally it can be the same model; on Groq use a smaller/faster one.
JUDGE_MODEL=qwen2.5:7b

# --- Embeddings (local, free — runs on your CPU) ---------------------------
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- Retrieval knobs --------------------------------------------------------
# These defaults come from the literature; tuning rationale is in DECISIONS.md.
DENSE_TOP_K=10
SPARSE_TOP_K=10
RRF_K=60
DENSE_WEIGHT=0.7
RERANK_ENABLED=true
RERANK_TOP_N=20
FINAL_TOP_K=5

# --- Paths -------------------------------------------------------------------
DATA_DIR=data
CHROMA_DIR=.chroma
