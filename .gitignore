# Python
.venv/
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
.ruff_cache/
.coverage
dist/

# Secrets — never commit real keys
.env

# Data: large and regenerable (also keeps churn out of OneDrive/git).
# Exceptions: the golden eval set is hand-authored work, and the built indexes
# (.chroma/ + BM25 pickles) ARE committed — Railway builds the Docker image
# from the GitHub checkout, and the Dockerfile COPYs them into the image.
data/*
!data/golden/
!data/bm25_*.pkl

# Eval run outputs / caches
data/eval_runs/

# Frontend
node_modules/
frontend/dist/

# OS noise
Thumbs.db
.DS_Store
